<Window x:Class="BinaryDiffViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:model="clr-namespace:BinaryDiffViewer.Models"
        xmlns:vm="clr-namespace:BinaryDiffViewer.ViewModels"
        Title="BinaryDiffViewer" Height="720" Width="1280"
        MinHeight="500" MinWidth="800"
        Background="#F5F4F0"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- 比較ボタン（Primary） -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#185FA5" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1469B5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F4F90" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- その他ボタン（Secondary） -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#1A1A1A" />
            <Setter Property="BorderBrush" Value="#C0BEB8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F4F0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#ECEAE5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- キャンセルボタン -->
        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#A32D2D" />
            <Setter Property="BorderBrush" Value="#FCA5A5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FEF2F2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FEE2E2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <!-- ツールバー -->
        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#E0DED8"
                BorderThickness="0,0,0,1"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- メイン行：左ボタン群 ＋ 右ステータス -->
                <Grid Grid.Row="0" Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 左：ボタン群 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="比較"
                                Command="{Binding CompareCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,8,0" />
                        <Button Content="キャンセル"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource CancelButtonStyle}"
                                Visibility="{Binding IsComparing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Margin="0,0,8,0" />
                        <Button Content="結果をCSV出力"
                                Command="{Binding ExportCsvCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>

                    <!-- 右：インライン ステータス表示 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- 状態 + バッジ -->
                        <TextBlock Text="状態：" FontSize="12" Foreground="#888888" VerticalAlignment="Center" />
                        <Border CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F0EFEC" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Comparing}">
                                            <Setter Property="Background" Value="#E8F3FF" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Canceled}">
                                            <Setter Property="Background" Value="#FFF8E7" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Error}">
                                            <Setter Property="Background" Value="#FCEBEB" />
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Completed}" />
                                                <Condition Binding="{Binding HasDifferences}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#FCEBEB" />
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Completed}" />
                                                <Condition Binding="{Binding HasDifferences}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#EDFAF3" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding CompareStatus}"
                                       FontSize="12" FontWeight="Medium" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding CompareStatus}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#6B7280" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Comparing}">
                                                <Setter Property="Foreground" Value="#185FA5" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Canceled}">
                                                <Setter Property="Foreground" Value="#8A6A00" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Error}">
                                                <Setter Property="Foreground" Value="#A32D2D" />
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Completed}" />
                                                    <Condition Binding="{Binding HasDifferences}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="#A32D2D" />
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Completed}" />
                                                    <Condition Binding="{Binding HasDifferences}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="#1A7A45" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <Rectangle Width="1" Height="14" Fill="#E0DED8" Margin="12,0" VerticalAlignment="Center" />

                        <!-- 差分総数 -->
                        <TextBlock Text="差分総数：" FontSize="12" Foreground="#888888" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding DiffCountText}" FontSize="12" FontWeight="Medium" Foreground="#1A1A1A" VerticalAlignment="Center" />

                        <Rectangle Width="1" Height="14" Fill="#E0DED8" Margin="12,0" VerticalAlignment="Center" />

                        <!-- 最初の差分 -->
                        <TextBlock Text="最初の差分：" FontSize="12" Foreground="#888888" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding FirstDiffOffsetText}"
                                   FontSize="12" FontWeight="Medium" Foreground="#1A1A1A"
                                   FontFamily="Cascadia Mono, Consolas" VerticalAlignment="Center" />

                        <Rectangle Width="1" Height="14" Fill="#E0DED8" Margin="12,0" VerticalAlignment="Center" />

                        <!-- サイズ -->
                        <TextBlock Text="サイズ：" FontSize="12" Foreground="#888888" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SameSizeText}" FontSize="12" FontWeight="Medium" Foreground="#1A1A1A" VerticalAlignment="Center" />

                        <Rectangle Width="1" Height="14" Fill="#E0DED8" Margin="12,0" VerticalAlignment="Center" />

                        <!-- 選択中 -->
                        <TextBlock Text="選択中：" FontSize="12" Foreground="#888888" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SelectedDiffOffsetText}"
                                   FontSize="12" FontWeight="Medium" Foreground="#1A1A1A"
                                   FontFamily="Cascadia Mono, Consolas" VerticalAlignment="Center" />

                        <!-- 進捗（比較中のみ表示） -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsComparing, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Rectangle Width="1" Height="14" Fill="#E0DED8" Margin="12,0" VerticalAlignment="Center" />
                            <TextBlock Text="進捗：" FontSize="12" Foreground="#888888" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ProgressText}"
                                       FontSize="12" FontWeight="Medium" Foreground="#1A1A1A"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- 比較中プログレスバー（下端） -->
                <ProgressBar Grid.Row="1"
                             Value="{Binding ProgressPercentage, Mode=OneWay}"
                             Minimum="0" Maximum="100"
                             Height="3"
                             Foreground="#4ADE80"
                             Background="Transparent"
                             BorderThickness="0"
                             Visibility="{Binding IsComparing, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </Border>

        <!-- 16進数表示エリア（左右分割） -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ファイルA（左側） -->
            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="ファイルAを開く"
                            Command="{Binding OpenFileACommand}"
                            IsEnabled="{Binding IsFileSelectionEnabled}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0"
                            Padding="10,4" />
                </StackPanel>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="パス：" VerticalAlignment="Center" Foreground="#6B7280" />
                    <TextBox   Grid.Column="1" Text="{Binding FileAPath, Mode=OneWay}"
                               IsReadOnly="True" Margin="4,0" VerticalAlignment="Center"
                               Background="#FFFFFF" BorderBrush="#E0DED8" Foreground="#1A1A1A" />
                    <TextBlock Grid.Column="2" Text="サイズ：" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#6B7280" />
                    <TextBlock Grid.Column="3" Text="{Binding FileASize}" VerticalAlignment="Center" Margin="4,0" Foreground="#1A1A1A" />
                </Grid>

                <Border BorderBrush="#E0DED8" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                    <TextBox x:Name="FileAHexTextBox"
                             Text="{Binding FileAHexContent, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="12"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             Background="#FFFFFF"
                             Foreground="#1A1A1A"
                             CaretBrush="Transparent"
                             BorderThickness="0"
                             Padding="8"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto" />
                </Border>
            </DockPanel>

            <!-- 垂直スプリッター -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#E0DED8" />

            <!-- ファイルB（右側） -->
            <DockPanel Grid.Column="2">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="ファイルBを開く"
                            Command="{Binding OpenFileBCommand}"
                            IsEnabled="{Binding IsFileSelectionEnabled}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0"
                            Padding="10,4" />
                </StackPanel>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="パス：" VerticalAlignment="Center" Foreground="#6B7280" />
                    <TextBox   Grid.Column="1" Text="{Binding FileBPath, Mode=OneWay}"
                               IsReadOnly="True" Margin="4,0" VerticalAlignment="Center"
                               Background="#FFFFFF" BorderBrush="#E0DED8" Foreground="#1A1A1A" />
                    <TextBlock Grid.Column="2" Text="サイズ：" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#6B7280" />
                    <TextBlock Grid.Column="3" Text="{Binding FileBSize}" VerticalAlignment="Center" Margin="4,0" Foreground="#1A1A1A" />
                </Grid>

                <Border BorderBrush="#E0DED8" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                    <TextBox x:Name="FileBHexTextBox"
                             Text="{Binding FileBHexContent, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="12"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             Background="#FFFFFF"
                             Foreground="#1A1A1A"
                             CaretBrush="Transparent"
                             BorderThickness="0"
                             Padding="8"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto" />
                </Border>
            </DockPanel>
        </Grid>

        <!-- 水平スプリッター -->
        <GridSplitter Grid.Row="2"
                      Height="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#E0DED8" />

        <!-- 差分一覧 -->
        <Border Grid.Row="3" Margin="0,4,0,0"
                BorderBrush="#E0DED8" BorderThickness="1" CornerRadius="6">
            <DataGrid x:Name="DiffItemsDataGrid"
                      ItemsSource="{Binding DiffItems}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      FontFamily="Cascadia Mono, Consolas"
                      FontSize="12"
                      Background="#FFFFFF"
                      Foreground="#1A1A1A"
                      RowBackground="#FFFFFF"
                      AlternatingRowBackground="#F5F4F0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E0DED8"
                      BorderThickness="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      SelectionMode="Single"
                      CanUserResizeRows="False"
                      IsEnabled="{Binding IsDiffItemsEnabled}"
                      SelectionChanged="DiffItemsDataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Offset"      Binding="{Binding Offset}"    Width="130" />
                    <DataGridTextColumn Header="File A Byte" Binding="{Binding FileAByte}" Width="110" />
                    <DataGridTextColumn Header="File B Byte" Binding="{Binding FileBByte}" Width="110" />
                    <DataGridTextColumn Header="Diff Type"   Binding="{Binding DiffType}"  Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
