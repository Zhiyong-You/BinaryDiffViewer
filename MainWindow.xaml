<Window x:Class="BinaryDiffViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:model="clr-namespace:BinaryDiffViewer.Models"
        xmlns:vm="clr-namespace:BinaryDiffViewer.ViewModels"
        Title="BinaryDiffViewer" Height="720" Width="1280"
        MinHeight="500" MinWidth="800"
        Background="#F5F4F0"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#1A1A1A" />
            <Setter Property="BorderBrush" Value="#E0DED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="96" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F4F0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderActionButtonStyle}">
            <Setter Property="Background" Value="#FEF2F2" />
            <Setter Property="Foreground" Value="#991B1B" />
            <Setter Property="BorderBrush" Value="#FCA5A5" />
            <Setter Property="MinWidth" Value="112" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FEE2E2" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E0DED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="52" />
        </Style>

        <Style x:Key="BadgeLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="BadgeValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border" BasedOn="{StaticResource HeaderBadgeStyle}">
            <Setter Property="Background" Value="#F5F4F0" />
            <Setter Property="BorderBrush" Value="#E0DED8" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Idle}">
                    <Setter Property="Background" Value="#F5F4F0" />
                    <Setter Property="BorderBrush" Value="#E0DED8" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Ready}">
                    <Setter Property="Background" Value="#EFF6FF" />
                    <Setter Property="BorderBrush" Value="#93C5FD" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Comparing}">
                    <Setter Property="Background" Value="#ECFEFF" />
                    <Setter Property="BorderBrush" Value="#67E8F9" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Canceled}">
                    <Setter Property="Background" Value="#FFFBEB" />
                    <Setter Property="BorderBrush" Value="#FDE68A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Error}">
                    <Setter Property="Background" Value="#FEF2F2" />
                    <Setter Property="BorderBrush" Value="#FCA5A5" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Completed}" />
                        <Condition Binding="{Binding HasDifferences}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FFF7ED" />
                    <Setter Property="BorderBrush" Value="#FCD34D" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding CurrentUiState}" Value="{x:Static model:CompareUiState.Completed}" />
                        <Condition Binding="{Binding HasDifferences}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#F0FDF4" />
                    <Setter Property="BorderBrush" Value="#86EFAC" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <!-- ヘッダー（ツールバー兼ステータス領域） -->
        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#E0DED8"
                BorderThickness="1"
                Height="92"
                Padding="12,10"
                Margin="0,0,0,8"
                CornerRadius="6">
            <Grid>
                <Grid Visibility="{Binding IsStatisticsMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="比較"
                                Command="{Binding CompareCommand}"
                                Style="{StaticResource HeaderActionButtonStyle}" />
                        <Button Content="結果をCSV出力"
                                Command="{Binding ExportCsvCommand}"
                                Style="{StaticResource HeaderActionButtonStyle}"
                                MinWidth="132"
                                Margin="0" />
                    </StackPanel>

                    <UniformGrid Grid.Column="2" Columns="4" Rows="1" VerticalAlignment="Center">
                        <Border Style="{StaticResource StatusBadgeStyle}">
                            <StackPanel>
                                <TextBlock Text="状態" Style="{StaticResource BadgeLabelTextStyle}" />
                                <TextBlock Text="{Binding CompareStatus}"
                                           Style="{StaticResource BadgeValueTextStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding CompareStatus}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource HeaderBadgeStyle}">
                            <StackPanel>
                                <TextBlock Text="差分総数" Style="{StaticResource BadgeLabelTextStyle}" />
                                <TextBlock Text="{Binding DiffCountText}" Style="{StaticResource BadgeValueTextStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource HeaderBadgeStyle}">
                            <StackPanel>
                                <TextBlock Text="最初の差分" Style="{StaticResource BadgeLabelTextStyle}" />
                                <TextBlock Text="{Binding FirstDiffOffsetText}"
                                           Style="{StaticResource BadgeValueTextStyle}"
                                           FontFamily="Cascadia Mono, Consolas" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource HeaderBadgeStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="ファイルサイズ" Style="{StaticResource BadgeLabelTextStyle}" />
                                <TextBlock Text="{Binding SameSizeText}" Style="{StaticResource BadgeValueTextStyle}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Grid.Column="4" Style="{StaticResource HeaderBadgeStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="選択中の差分" Style="{StaticResource BadgeLabelTextStyle}" />
                            <TextBlock Text="{Binding SelectedDiffOffsetText}"
                                       Style="{StaticResource BadgeValueTextStyle}"
                                       FontFamily="Cascadia Mono, Consolas" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding IsComparing, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="キャンセル"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource CancelButtonStyle}"
                            Margin="0"
                            VerticalAlignment="Center" />

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Border Style="{StaticResource StatusBadgeStyle}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="状態" Style="{StaticResource BadgeLabelTextStyle}" />
                                <TextBlock Text="{Binding CompareStatus}" Style="{StaticResource BadgeValueTextStyle}" />
                            </StackPanel>
                        </Border>

                        <ProgressBar Value="{Binding ProgressPercentage, Mode=OneWay}"
                                     Minimum="0"
                                     Maximum="100"
                                     Height="6"
                                     Foreground="#4ADE80"
                                     Background="#E0DED8"
                                     BorderThickness="0" />
                    </StackPanel>

                    <Border Grid.Column="4" Style="{StaticResource HeaderBadgeStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="進捗" Style="{StaticResource BadgeLabelTextStyle}" />
                            <TextBlock Text="{Binding ProgressText}"
                                       Style="{StaticResource BadgeValueTextStyle}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- 16進数表示エリア（左右分割） -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ファイルA（左側） -->
            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="ファイルAを開く"
                            Command="{Binding OpenFileACommand}"
                            IsEnabled="{Binding IsFileSelectionEnabled}"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            Margin="0"
                            Padding="10,4" />
                </StackPanel>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="パス：" VerticalAlignment="Center" Foreground="#6B7280" />
                    <TextBox   Grid.Column="1" Text="{Binding FileAPath, Mode=OneWay}"
                               IsReadOnly="True" Margin="4,0" VerticalAlignment="Center"
                               Background="#FFFFFF" BorderBrush="#E0DED8" Foreground="#1A1A1A" />
                    <TextBlock Grid.Column="2" Text="サイズ：" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#6B7280" />
                    <TextBlock Grid.Column="3" Text="{Binding FileASize}" VerticalAlignment="Center" Margin="4,0" Foreground="#1A1A1A" />
                </Grid>

                <Border BorderBrush="#E0DED8" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                    <TextBox x:Name="FileAHexTextBox"
                             Text="{Binding FileAHexContent, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="12"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             Background="#FFFFFF"
                             Foreground="#1A1A1A"
                             CaretBrush="Transparent"
                             BorderThickness="0"
                             Padding="8"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto" />
                </Border>
            </DockPanel>

            <!-- 垂直スプリッター -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#E0DED8" />

            <!-- ファイルB（右側） -->
            <DockPanel Grid.Column="2">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="ファイルBを開く"
                            Command="{Binding OpenFileBCommand}"
                            IsEnabled="{Binding IsFileSelectionEnabled}"
                            Style="{StaticResource HeaderActionButtonStyle}"
                            Margin="0"
                            Padding="10,4" />
                </StackPanel>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="パス：" VerticalAlignment="Center" Foreground="#6B7280" />
                    <TextBox   Grid.Column="1" Text="{Binding FileBPath, Mode=OneWay}"
                               IsReadOnly="True" Margin="4,0" VerticalAlignment="Center"
                               Background="#FFFFFF" BorderBrush="#E0DED8" Foreground="#1A1A1A" />
                    <TextBlock Grid.Column="2" Text="サイズ：" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#6B7280" />
                    <TextBlock Grid.Column="3" Text="{Binding FileBSize}" VerticalAlignment="Center" Margin="4,0" Foreground="#1A1A1A" />
                </Grid>

                <Border BorderBrush="#E0DED8" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                    <TextBox x:Name="FileBHexTextBox"
                             Text="{Binding FileBHexContent, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="12"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             Background="#FFFFFF"
                             Foreground="#1A1A1A"
                             CaretBrush="Transparent"
                             BorderThickness="0"
                             Padding="8"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto" />
                </Border>
            </DockPanel>
        </Grid>

        <!-- 水平スプリッター -->
        <GridSplitter Grid.Row="2"
                      Height="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#E0DED8" />

        <!-- 差分一覧 -->
        <Border Grid.Row="3" Margin="0,4,0,0"
                BorderBrush="#E0DED8" BorderThickness="1" CornerRadius="6">
            <DataGrid x:Name="DiffItemsDataGrid"
                      ItemsSource="{Binding DiffItems}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      FontFamily="Cascadia Mono, Consolas"
                      FontSize="12"
                      Background="#FFFFFF"
                      Foreground="#1A1A1A"
                      RowBackground="#FFFFFF"
                      AlternatingRowBackground="#F5F4F0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E0DED8"
                      BorderThickness="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      SelectionMode="Single"
                      CanUserResizeRows="False"
                      IsEnabled="{Binding IsDiffItemsEnabled}"
                      SelectionChanged="DiffItemsDataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Offset"      Binding="{Binding Offset}"    Width="130" />
                    <DataGridTextColumn Header="File A Byte" Binding="{Binding FileAByte}" Width="110" />
                    <DataGridTextColumn Header="File B Byte" Binding="{Binding FileBByte}" Width="110" />
                    <DataGridTextColumn Header="Diff Type"   Binding="{Binding DiffType}"  Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
