<Window x:Class="BinaryDiffViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BinaryDiffViewer.ViewModels"
        Title="BinaryDiffViewer" Height="720" Width="1280"
        MinHeight="500" MinWidth="800">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- 比較バー -->
            <RowDefinition Height="3*" />     <!-- 16進数表示エリア -->
            <RowDefinition Height="5" />      <!-- 水平スプリッター -->
            <RowDefinition Height="1*" />     <!-- 差分一覧 -->
        </Grid.RowDefinitions>

        <!-- 比較バー（全幅・上部） -->
        <Border Grid.Row="0"
                Background="#252526"
                Padding="10,7"
                Margin="0,0,0,8"
                CornerRadius="3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- ボタン群 -->
                    <ColumnDefinition Width="180" />   <!-- プログレスバー -->
                    <ColumnDefinition Width="*" />     <!-- 状態テキスト -->
                </Grid.ColumnDefinitions>

                <!-- ボタン群 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="比較"
                            Command="{Binding CompareCommand}"
                            Padding="18,4"
                            Margin="0,0,8,0" />
                    <Button Content="キャンセル"
                            Command="{Binding CancelCommand}"
                            Padding="12,4" />
                </StackPanel>

                <!-- プログレスバー -->
                <ProgressBar Grid.Column="1"
                             Value="{Binding Progress, Mode=OneWay}"
                             Minimum="0" Maximum="100"
                             Height="14"
                             Margin="16,0"
                             VerticalAlignment="Center" />

                <!-- 状態テキスト -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="状態：" VerticalAlignment="Center" Foreground="#AAAAAA" />
                    <TextBlock Text="{Binding CompareStatus}" VerticalAlignment="Center"
                               Foreground="#4EC9B0" FontWeight="Bold" Margin="4,0,20,0" />

                    <TextBlock Text="差分総数：" VerticalAlignment="Center" Foreground="#AAAAAA" />
                    <TextBlock Text="{Binding DiffCountText}" VerticalAlignment="Center"
                               Foreground="#CE9178" Margin="4,0,20,0" />

                    <TextBlock Text="最初の差分：" VerticalAlignment="Center" Foreground="#AAAAAA" />
                    <TextBlock Text="{Binding FirstDiffOffsetText}" VerticalAlignment="Center"
                               Foreground="#CE9178" FontFamily="Consolas" Margin="4,0,20,0" />

                    <TextBlock Text="ファイルサイズ：" VerticalAlignment="Center" Foreground="#AAAAAA" />
                    <TextBlock Text="{Binding SameSizeText}" VerticalAlignment="Center"
                               Foreground="#CE9178" Margin="4,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 16進数表示エリア（左右分割） -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ファイルA（左側） -->
            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="ファイルAを開く"
                            Command="{Binding OpenFileACommand}"
                            Padding="10,4" />
                </StackPanel>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="パス：" VerticalAlignment="Center" />
                    <TextBox   Grid.Column="1" Text="{Binding FileAPath, Mode=OneWay}"
                               IsReadOnly="True" Margin="4,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="サイズ：" VerticalAlignment="Center" Margin="12,0,0,0" />
                    <TextBlock Grid.Column="3" Text="{Binding FileASize}" VerticalAlignment="Center" Margin="4,0" />
                </Grid>

                <TextBox Text="{Binding FileAHexContent, Mode=OneWay}"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="13"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         Background="#1E1E1E"
                         Foreground="#D4D4D4"
                         CaretBrush="Transparent"
                         BorderThickness="1"
                         Padding="4"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto" />
            </DockPanel>

            <!-- 垂直スプリッター -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#3F3F46" />

            <!-- ファイルB（右側） -->
            <DockPanel Grid.Column="2">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="ファイルBを開く"
                            Command="{Binding OpenFileBCommand}"
                            Padding="10,4" />
                </StackPanel>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="パス：" VerticalAlignment="Center" />
                    <TextBox   Grid.Column="1" Text="{Binding FileBPath, Mode=OneWay}"
                               IsReadOnly="True" Margin="4,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="サイズ：" VerticalAlignment="Center" Margin="12,0,0,0" />
                    <TextBlock Grid.Column="3" Text="{Binding FileBSize}" VerticalAlignment="Center" Margin="4,0" />
                </Grid>

                <TextBox Text="{Binding FileBHexContent, Mode=OneWay}"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="13"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         Background="#1E1E1E"
                         Foreground="#D4D4D4"
                         CaretBrush="Transparent"
                         BorderThickness="1"
                         Padding="4"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto" />
            </DockPanel>
        </Grid>

        <!-- 水平スプリッター -->
        <GridSplitter Grid.Row="2"
                      Height="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#3F3F46" />

        <!-- 差分一覧 -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding DiffItems}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  FontFamily="Consolas"
                  FontSize="12"
                  Background="#1E1E1E"
                  Foreground="#D4D4D4"
                  RowBackground="#1E1E1E"
                  AlternatingRowBackground="#252526"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#3F3F46"
                  BorderThickness="1"
                  Margin="0,4,0,0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  SelectionMode="Single"
                  CanUserResizeRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Offset"      Binding="{Binding Offset}"    Width="130" />
                <DataGridTextColumn Header="File A Byte" Binding="{Binding FileAByte}" Width="110" />
                <DataGridTextColumn Header="File B Byte" Binding="{Binding FileBByte}" Width="110" />
                <DataGridTextColumn Header="Diff Type"   Binding="{Binding DiffType}"  Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
