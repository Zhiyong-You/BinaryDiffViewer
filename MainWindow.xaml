<Window x:Class="BinaryDiffViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BinaryDiffViewer.ViewModels"
        Title="BinaryDiffViewer" Height="600" Width="960"
        MinHeight="400" MinWidth="600">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <DockPanel Margin="8">

        <!-- ツールバー -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="ファイルを開く"
                    Command="{Binding OpenFileCommand}"
                    Padding="10,4" />
        </StackPanel>

        <!-- ファイル情報 -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="パス：" VerticalAlignment="Center" />
            <TextBox  Grid.Column="1" Text="{Binding FilePath, Mode=OneWay}"
                      IsReadOnly="True" Margin="4,0"
                      VerticalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="サイズ：" VerticalAlignment="Center" Margin="12,0,0,0" />
            <TextBlock Grid.Column="3" Text="{Binding FileSize}" VerticalAlignment="Center" Margin="4,0" />
        </Grid>

        <!-- 16進数表示エリア -->
        <TextBox Text="{Binding HexContent, Mode=OneWay}"
                 IsReadOnly="True"
                 FontFamily="Consolas"
                 FontSize="13"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"
                 Background="#1E1E1E"
                 Foreground="#D4D4D4"
                 CaretBrush="Transparent"
                 BorderThickness="1"
                 Padding="4"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto" />
    </DockPanel>
</Window>
